{
  "name": "orbital-settlement-protocol",
  "scripts": {
    "anchor-build": "cd anchor && anchor build",
    "anchor-test": "cd anchor && anchor test --skip-deploy",
    "build": "next build",
    "ci": "npm run build && npm run lint && npm run format:check",
    "codama:js": "codama run js",
    "dev": "next dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint",
    "setup": "npm run anchor-build && npm run codama:js",
    "start": "next start",
    "deploy:devnet": "bash scripts/deploy-devnet.sh",
    "bootstrap:devnet": "cd scripts && npm install && npm run bootstrap"
  },
  "description": "Orbital Settlement Protocol — Paradigm Orbital AMM on Solana with institutional settlement",
  "keywords": [
    "anchor",
    "solana",
    "orbital",
    "amm",
    "stablecoin",
    "settlement",
    "defi",
    "nextjs",
    "typescript"
  ],
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@solana/client": "^1.2.0",
    "@solana/kit": "^5.1.0",
    "@solana/react-hooks": "^1.1.5",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "framer-motion": "^12.35.2",
    "lucide-react": "^0.577.0",
    "next": "16.0.10",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "recharts": "^3.8.0",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@codama/nodes-from-anchor": "^1.3.8",
    "@codama/renderers-js": "^1.5.5",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "baseline-browser-mapping": "^2.10.7",
    "codama": "^1.5.0",
    "eslint": "^9",
    "eslint-config-next": "16.0.10",
    "prettier": "^3.6.2",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
